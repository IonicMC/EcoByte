EXHIBIT_LINK = "https://example.com"

# Optional logo for QR center icon
LOGO_PATH = "logo.png"


def qr_pixmap_from_text(text: str, logo_path: str, size_px: int = 560) -> QPixmap:
    qr = qrcode.QRCode(
        version=None,
        error_correction=qrcode.constants.ERROR_CORRECT_H,
        box_size=10,
        border=2
    )
    qr.add_data(text)
    qr.make(fit=True)

    img = qr.make_image(fill_color="#164863", back_color="white").convert("RGBA")
    img = img.resize((size_px, size_px), Image.Resampling.LANCZOS)

    if os.path.exists(logo_path):
        logo = Image.open(logo_path).convert("RGBA")
        logo_size = int(size_px * 0.22)
        logo = logo.resize((logo_size, logo_size), Image.Resampling.LANCZOS)

        logo_pos = ((size_px - logo_size) // 2, (size_px - logo_size) // 2)

        box_size = int(size_px * 0.26)
        box_pos = ((size_px - box_size) // 2, (size_px - box_size) // 2)

        mask = Image.new("L", (size_px, size_px), 255)
        draw = ImageDraw.Draw(mask)
        draw.ellipse([box_pos, (box_pos[0] + box_size, box_pos[1] + box_size)], fill=0)

        img.putalpha(mask)
        img.paste(logo, logo_pos, logo)

    img = img.convert("RGB")
    img_data = img.tobytes("raw", "RGB")
    q_img = QImage(img_data, size_px, size_px, 3 * size_px, QImage.Format.Format_RGB888)

    return QPixmap.fromImage(q_img)


class DemoMachineBackend:
    """
    This is a SAFE mock backend.

    In the private build, this is where your:
    - GPIO bottle detection
    - IR verification
    - servo open/close
    - camera ONNX validation
    - firebase redeem/deposit
    would exist.
    """

    def __init__(self):
        self.points = 0
        self.bottle_count = 0

    def simulate_bottle_drop(self):
        """Simulates bottle detection (demo mode)."""
        self.bottle_count += 1
        self.points += 5

    def generate_token(self):
        """Generates a mock claim token."""
        return str(uuid.uuid4()).split("-")[0].upper()


