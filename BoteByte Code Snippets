        self.backend = DemoMachineBackend()
        self.last_interaction = time.time()

        self.title = QLabel("BoteByte Exhibit Demo")
        self.title.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.title.setStyleSheet("color: #164863; font-size: 48px; font-weight: 900;")
        self.title.setFont(QFont("Arial", 22))

        self.subtitle = QLabel("Scan the QR Code to learn more")
        self.subtitle.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.subtitle.setStyleSheet("color: #0f172a; font-size: 20px;")

        self.qr_label = QLabel()
        self.qr_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.qr_label.setPixmap(qr_pixmap_from_text(EXHIBIT_LINK, LOGO_PATH))

        self.stats_frame = QFrame()
        self.stats_frame.setStyleSheet("""
            QFrame {
                background: white;
                border-radius: 18px;
                border: 3px solid #164863;
            }
        """)

        stats_layout = QVBoxLayout(self.stats_frame)

        self.points_label = QLabel("Points: 0")
        self.points_label.setStyleSheet("font-size: 26px; font-weight: 800; color: #164863;")
        self.points_label.setAlignment(Qt.AlignmentFlag.AlignCenter)

        self.bottle_label = QLabel("Bottles: 0")
        self.bottle_label.setStyleSheet("font-size: 22px; font-weight: 700; color: #0f172a;")
        self.bottle_label.setAlignment(Qt.AlignmentFlag.AlignCenter)

        stats_layout.addWidget(self.points_label)
        stats_layout.addWidget(self.bottle_label)

        self.simulate_btn = QPushButton("SIMULATE BOTTLE DROP")
        self.simulate_btn.setStyleSheet("""
            QPushButton {
                background: #10b981;
                color: white;
                font-size: 22px;
                font-weight: 900;
                border-radius: 18px;
                padding: 18px;
            }
            QPushButton:hover {
                background: #059669;
            }
        """)
        self.simulate_btn.clicked.connect(self.simulate_drop)

        self.token_btn = QPushButton("GENERATE CLAIM TOKEN")
        self.token_btn.setStyleSheet("""
            QPushButton {
                background: #164863;
                color: white;
                font-size: 20px;
                font-weight: 900;
                border-radius: 18px;
                padding: 18px;
            }
            QPushButton:hover {
                background: #0f3550;
            }
        """)
        self.token_btn.clicked.connect(self.generate_claim)

        self.token_label = QLabel("Token: ---")
        self.token_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.token_label.setStyleSheet("font-size: 22px; font-weight: 800; color: #0f172a;")

        btn_row = QHBoxLayout()
        btn_row.addWidget(self.simulate_btn)
        btn_row.addWidget(self.token_btn)

        root = QVBoxLayout(self)
        root.setContentsMargins(40, 40, 40, 40)
        root.setSpacing(25)

        root.addWidget(self.title)
        root.addWidget(self.subtitle)
        root.addWidget(self.qr_label)
        root.addWidget(self.stats_frame)
        root.addLayout(btn_row)
        root.addWidget(self.token_label)

        self.timer = QTimer()
        self.timer.timeout.connect(self.check_idle)
        self.timer.start(1000)

    def simulate_drop(self):
        self.last_interaction = time.time()
        self.backend.simulate_bottle_drop()
        self.refresh_stats()

    def generate_claim(self):
        self.last_interaction = time.time()
        token = self.backend.generate_token()
        self.token_label.setText(f"Token: {token}")

    def refresh_stats(self):
        self.points_label.setText(f"Points: {self.backend.points}")
        self.bottle_label.setText(f"Bottles: {self.backend.bottle_count}")

    def check_idle(self):
        if (time.time() - self.last_interaction) * 1000 > IDLE_TIMEOUT_MS:
            self.token_label.setText("Token: ---")
            # reset view behavior can go here
            self.last_interaction = time.time()


